generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Listing {
  id       String  @id
  title    String
  price    Int
  currency String
  sourcePrice Int?
  url      String  @unique
  location String?
  description String?
  imageUrl String?
  rooms    Int?
  category String?
  sellerType String?
  source   String  @default("kufar.by")
  isActive Boolean @default(true)
  contentHash String?
  missingCount Int @default(0)

  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  events       AdEvent[]

  @@index([source])
}

model User {
  id             String  @id @default(cuid())
  name           String?
  telegramChatId String
  planId         String?
  planExpiresAt  DateTime?

  plan           Plan? @relation(fields: [planId], references: [id])
  subscriptions Subscription[]
  billingSubscriptions UserSubscription[]
  telegramDeliveryLogs TelegramDeliveryLog[]

  createdAt DateTime @default(now())
}

model Plan {
  id                     String  @id
  name                   String
  subscriptionsLimit     Int?
  minimumIntervalMinutes Int
  enabled                Boolean @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  users                 User[]
  billingSubscriptions  UserSubscription[]
}

model UserSubscription {
  id         String   @id @default(cuid())
  userId     String
  planId     String
  status     String   @default("ACTIVE")
  startedAt  DateTime @default(now())
  expiresAt  DateTime
  autoRenew  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  @@index([userId, status])
  @@index([expiresAt])
}

model AdEvent {
  id          String   @id @default(cuid())
  listingId   String
  eventType   String
  changesJson Json
  createdAt   DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, createdAt])
  @@index([eventType])
}

model TelegramDeliveryLog {
  id          String   @id @default(cuid())
  userId      String?
  userLabel   String?
  chatId      String
  purpose     String
  success     Boolean
  statusCode  Int?
  error       String?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([createdAt])
}

model Subscription {
  id              String   @id @default(cuid())
  name            String
  userId          String?
  source          String   @default("kufar.by")
  category        String?
  sellerTypeFilter String   @default("all")
  notificationMode String   @default("new_and_changed")
  maxPrice        Int?
  rooms           Json?
  filters         Json?
  intervalMinutes Int      @default(30)
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([source])
}
