generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Listing {
  id       String  @id
  title    String
  price    Int
  currency String
  url      String  @unique
  location String?
  description String?
  imageUrl String?
  rooms    Int?
  category String?
  source   String  @default("kufar")
  isActive Boolean @default(true)
  contentHash String?
  missingCount Int @default(0)

  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  events       AdEvent[]
}

model User {
  id             String  @id @default(cuid())
  name           String?
  telegramChatId String

  subscriptions Subscription[]

  createdAt DateTime @default(now())
}

model AdEvent {
  id          String   @id @default(cuid())
  listingId   String
  eventType   String
  changesJson Json
  createdAt   DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, createdAt])
  @@index([eventType])
}

model Subscription {
  id              String   @id @default(cuid())
  name            String
  userId          String?
  category        String?
  maxPrice        Int?
  rooms           Json?
  filters         Json?
  intervalMinutes Int      @default(30)
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}
